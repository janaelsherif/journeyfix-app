# Database (PostgreSQL - Supabase or local)
DATABASE_URL="postgresql://user:password@localhost:5432/journeyfix"

# Anthropic API for AI analysis
ANTHROPIC_API_KEY="sk-ant-..."

# App URL (for emails and redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend for email delivery
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="JourneyFix <noreply@yourdomain.com>"

# Stripe for payments
STRIPE_SECRET_KEY="sk_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_..."

# Pricing ladder (CHF inkl. MwSt.; Nexilon-aligned defaults: Basic 99, Advanced 199)
BASIC_PRICE_CHF=99
ADVANCED_PRICE_CHF=199
NEXT_PUBLIC_BASIC_PRICE_CHF=99
NEXT_PUBLIC_ADVANCED_PRICE_CHF=199

# Module B & C add-on price (Nexilon ladder; default 299)
MODULE_BC_CHF=299
NEXT_PUBLIC_MODULE_BC_CHF=299

# Legacy single “premium” display (Advanced tier)
PREMIUM_PRICE_CHF=199
NEXT_PUBLIC_PREMIUM_PRICE_CHF=199

# Brevo — POST /api/subscribe (EmailCaptureWidget + report dialog + PraxisTrust).
# Contacts get attribute SOURCE_JOURNEYFIX (per-page source, see subscribe-sources.ts).
BREVO_API_KEY=
# Optional: comma-separated list IDs — applied only when marketingConsent is true
BREVO_LIST_IDS=

# Plausible Analytics (optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="journeyfix.ch"
