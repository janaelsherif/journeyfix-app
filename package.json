{
  "name": "journeyfix-app",
  "version": "1.0.0",
  "description": "JourneyFix.ch - AI-powered website customer journey auditing for Swiss professional services",
  "private": true,
  "scripts": {
    "dev": "env -u PLAYWRIGHT_BROWSERS_PATH next dev",
    "clean": "rm -rf .next node_modules/.cache",
    "dev:clean": "npm run clean && env -u PLAYWRIGHT_BROWSERS_PATH next dev",
    "dev:fresh": "npm run clean && env -u PLAYWRIGHT_BROWSERS_PATH next dev",
    "dev:3002": "env -u PLAYWRIGHT_BROWSERS_PATH next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "env -u PLAYWRIGHT_BROWSERS_PATH playwright test",
    "test:payment": "env -u PLAYWRIGHT_BROWSERS_PATH playwright test e2e/payment.spec.ts",
    "playwright:install": "playwright install chromium",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:docker:up": "docker compose up -d",
    "db:docker:down": "docker compose down",
    "db:setup": "node scripts/setup-db.js",
    "setup": "node scripts/setup.js",
    "test:e2e": "env -u PLAYWRIGHT_BROWSERS_PATH playwright test",
    "test:e2e:ui": "env -u PLAYWRIGHT_BROWSERS_PATH playwright test --ui"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@supabase/supabase-js": "^2.45.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.400.0",
    "next": "^14.2.0",
    "playwright": "^1.41.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.0",
    "recharts": "^2.12.0",
    "resend": "^3.2.0",
    "stripe": "^14.21.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "prisma": "^5.8.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}